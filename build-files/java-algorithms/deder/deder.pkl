amends "https://sake92.github.io/deder/config/v0.7.2/DederProject.pkl"

local const _pair =
  new CreateJavaModules {
    root = "."
    layout = "maven"
    template = new JavaModule {
      deps {
        "org.apache.commons:commons-lang3:3.20.0"
        "org.apache.commons:commons-collections4:4.5.0"
      }
    }
    testTemplate = (template.asTest()) {
      testParallelism = 1
      deps {
        "com.github.sbt.junit:jupiter-interface:0.16.0"
        "org.junit.jupiter:junit-jupiter:5.14.0"
        "org.junit.jupiter:junit-jupiter-engine:5.14.0"
        "org.assertj:assertj-core:3.27.6"
        "org.mockito:mockito-core:5.20.0"
      }
    }
  }.get

local const algorithms = (_pair.main) {
  id = "algorithms"
}
local const algorithmsTest = (_pair.test) {
  id = "algorithms-test"
  moduleDeps = new Listing { algorithms }
}

modules {
  algorithms
  algorithmsTest
}
